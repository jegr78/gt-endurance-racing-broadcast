# Solo profile (kind=solo) — a single-event commentary/POV broadcast.
# The main program is a local capture card + webcam in OBS (no A/B stint
# feeds). It still uses a Google Sheet (below). Created by `racecast profile new`.

# Display name shown in the CLI / Control Center / docs.
NAME=GT Solo POV Demo

# Profile kind: solo (vs. the classic feed-/sheet-driven `endurance`).
KIND=solo

# Starter template chosen at creation: commentary | pov. The matching OBS
# scene-collection source is materialized by `racecast setup` (#303).
TEMPLATE=pov

# Google Sheet that drives the HUD, timer, crew/console roles, broadcast
# chat and assets (the long ID from the sheet URL). A solo Sheet uses the
# same tabs as endurance MINUS the Schedule/Qualifying tabs.
SHEET_ID=1Qb-TLot9dCysoy9o4F4fp86PapFh-hILu5uafH8-J6c

# OPTIONAL: sheet-write webhook (Apps Script /exec URL incl. its ?key=...)
# enabling the Director Panel's Setup/POV write-back + the race timer.
SHEET_PUSH_URL=

# OPTIONAL: the OBS scene-collection name this profile uses. Blank = the
# product default per kind.
OBS_COLLECTION=GT Racing Solo — POV Demo

# OPTIONAL: a logo image (path relative to this profile dir), shown next
# to the profile name in the Control Center sidebar.
LOGO=logo.svg

# OPTIONAL: a free-text event title shown in the Director Panel and every
# Discord message (e.g. "GT Racing - Round 4 - Le Mans").
EVENT_TITLE=

# OPTIONAL: per-console secret. Auto-provisioned on first relay start;
# travels with `profile export`. Leave blank. Treat it like a password.
CONSOLE_SECRET=
