# GT Demo League — a ready-to-run, de-branded demo profile.
#
# This profile is directly usable (it appears in `racecast profile list`). It
# points at a PUBLIC, read-only demo Google Sheet, so you can try the toolkit
# end to end without owning a Sheet yet:
#
#     racecast profile use demo
#     racecast graphics          # pull the demo graphics from the Sheet's Assets tab
#     racecast media             # pull the demo intro/outro clips
#     racecast relay start       # serve the HUD/feeds to OBS
#
# To run your OWN league, copy this into a new profile and swap the SHEET_ID:
#     racecast profile new <your-league> --from demo
# The full Sheet layout is documented in the wiki page "Sheet-Template" (and the
# write-back Apps Script in "Sheet-Webhook").

# Display name shown in the CLI / Control Center / docs (not the HUD).
NAME=GT Demo League

# The PUBLIC demo Google Sheet (read-only). Replace with your own Sheet's ID
# (the long ID from https://docs.google.com/spreadsheets/d/<THIS_PART>/edit).
SHEET_ID=1Qb-TLot9dCysoy9o4F4fp86PapFh-hILu5uafH8-J6c

# OPTIONAL: sheet-write webhook (Google Apps Script /exec URL incl. its ?key=...
# secret) for Director write-back (timer + panel controls). Left BLANK here: the
# demo Sheet is read-only, so no write credential ships in git. Add your own to
# enable write-back — see the "Sheet-Webhook" wiki page.
SHEET_PUSH_URL=

# OPTIONAL: override the Intro/Outro clip URLs (normally taken from the Sheet's
# Assets tab cells "Intro Video" / "Outro Video").
INTRO_URL=
OUTRO_URL=

# OPTIONAL: a Discord webhook URL for live broadcast-health alerts. Blank = off.
DISCORD_WEBHOOK_URL=

# A neutral placeholder league logo (PNG/JPG/WebP/GIF/SVG), path relative to this
# profile dir, shown next to the profile name in the Control Center sidebar.
LOGO=logo.svg

# The OBS scene-collection name this league uses. Lets several leagues keep
# separate collections in OBS on one machine (switch with
# `racecast obs collection set`).
OBS_COLLECTION=GT Endurance Racing — Demo

# OPTIONAL: per-league secret for the Commentator Cockpit. Auto-generated on
# first relay start; travels with `profile export`. Leave blank.
CONSOLE_SECRET=

# OPTIONAL: a free-text event title shown in the Director Panel, the Commentator
# Cockpit and every Discord message. Blank = the surfaces keep their static headers.
EVENT_TITLE=

# Discord OAuth login for /console (optional; per-league app at discord.com/developers).
# Scope is identify only — NOT a bot. Blank = signed per-person links remain the
# only entry path. See `racecast links`.
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
