# IRO broadcast — machine-local config. Copy to ".env" (gitignored) and fill in.
#   cp .env.example .env
# Real environment variables take precedence over values in this file.

# Google Sheet that drives the HUD + relay stint schedule (the long ID from the
# sheet URL: https://docs.google.com/spreadsheets/d/<THIS_PART>/edit).
# Used by the relay (schedule/POV tabs) and by setup-assets.py (HUD browser source).
IRO_SHEET_ID=

# Full stagetimer.io output URL incl. its signature (a secret — anyone with the
# link can view the timer). Injected into the OBS timer browser source by
# setup-assets.py. Get it from stagetimer.io -> Output -> copy the signed link.
IRO_TIMER_URL=

# OPTIONAL: override the Intro/Outro clip URLs. Normally these come from the
# Google Sheet "Assets" tab (label cells "Intro Video" / "Outro Video").
# Set these only to override the sheet for this machine (used by get-media.py).
IRO_INTRO_URL=
IRO_OUTRO_URL=
