# GT Endurance Racing Broadcast -- machine-local config. Copy to ".env" (gitignored) and fill in.
#   cp .env.example .env
# Real environment variables take precedence over values in this file.
#
# League config (Google Sheet ID + push URL + intro/outro) is NOT here -- it
# lives per league in profiles/<name>/profile.env (see `racecast profile new`).

# OPTIONAL: OBS WebSocket password for the feed-port release on `racecast ... stop`
# (OBS is asked to stop the relay-fed media inputs so the feed ports tear down
# cleanly). Normally NOT needed -- the password is auto-read from OBS's own
# obs-websocket config on this machine. Set it only for portable/non-standard
# OBS installs where that config is not in the default location.
RACECAST_OBS_WS_PASSWORD=

# OPTIONAL (Windows): full path to Companion.exe for `racecast companion start/stop`.
# Only needed when Companion sits in a NON-standard location -- the standard
# install paths are found automatically, e.g. the winget / install-apps default:
#   RACECAST_COMPANION_EXE=C:\Program Files\Companion\Companion.exe
RACECAST_COMPANION_EXE=

# OPTIONAL: port of the local Control Center web app (`racecast ui`). Set this only
# when another application on this machine already occupies the default 8089.
RACECAST_UI_PORT=

# RESERVED for the future remote-support feature (Control Center over
# Tailscale): not read by any current version -- leave commented out.
# RACECAST_UI_PASSWORD=

# Default active profile (league) when neither --profile nor an explicit
# RACECAST_PROFILE env var is given. Each league lives in profiles/<name>/.
# Leave unset if you keep exactly one profile (it is then selected implicitly).
RACECAST_PROFILE=

# Days before a stored bandwidth speed-test result is treated as stale by
# `racecast preflight` (WARN: "re-measure before the event"). Default 7.
RACECAST_SPEEDTEST_MAX_AGE_DAYS=7

# Commentator Cockpit master switch for THIS machine (issue #191). true => the
# relay serves the talent-facing /cockpit page (still requires a per-league
# COCKPIT_SECRET in the active profile). Default off. Set by `racecast cockpit
# enable`. The cockpit is exposed publicly only when you also run
# `racecast cockpit funnel on` (Tailscale Funnel, /cockpit path only).
RACECAST_COCKPIT_ENABLED=false

# OPT-IN: bring the PUBLIC cockpit Funnel up automatically on `racecast event
# start` (best-effort; needs the cockpit enabled above + a one-time tailnet setup
# — MagicDNS, HTTPS, the 'funnel' nodeAttr). Default off so event start never
# exposes a public ingress unless you ask for it. Toggle in the Control Center
# Cockpit view or set here.
RACECAST_COCKPIT_FUNNEL=false

# OPTIONAL: Tailscale OAuth client for `racecast cockpit setup-funnel`, which
# automates the one-time tailnet prerequisites (enable MagicDNS + add the 'funnel'
# nodeAttr). Create one at https://login.tailscale.com/admin/settings/oauth with
# WRITE access to DNS and the Policy file (ACL). Only needed to run that one
# command; the secret is powerful (can rewrite the tailnet policy) — keep it here
# in .env (gitignored), never commit it.
RACECAST_TS_OAUTH_CLIENT_ID=
RACECAST_TS_OAUTH_CLIENT_SECRET=

# Discord interview audio on Linux without a native client (e.g. ARM64, where the
# official .deb is amd64-only): capture Discord-web from a browser instead.
# RACECAST_DISCORD_WEB: leave empty for auto (web when no native Discord is found),
# 1 to force the browser variant, 0 to force the native source.
# RACECAST_DISCORD_WEB_BROWSER: the browser process to capture (PipeWire match
# name) — defaults to a detected running browser, else Firefox.
#RACECAST_DISCORD_WEB=
#RACECAST_DISCORD_WEB_BROWSER=Firefox
